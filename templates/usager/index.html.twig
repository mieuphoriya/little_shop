{% extends 'base.html.twig' %}

{% block title %} Mon Compte {% endblock %}

{% block body %}
    <div class="main-div">
        <div class="card col-md-12">
            <div class="card-header">
                <a class="btn-back text-secondary" href="{{ path("app_default_index") }}">
                    <i class="fas fa-2x fa-arrow-circle-left"></i>
                </a>
                <h3>Mon Compte</h3>
            </div>
            <div class="card-body row">
                <table class="table">
                    <thead>
                    <tr>
                        <th>Email</th>
                        <th>Nom</th>
                        <th>Prenom</th>
                        <th>Mes Commandes</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% if app.user %}

                        <tr>
                            <td>{{ app.user.email }}</td>
                            <td>{{ app.user.nom }}</td>
                            <td>{{ app.user.prenom }}</td>
                            <td>
                                <a class="btn btn-sm btn-primary" href="{{ path("app_usager_commandes") }}">
                                    <span class="badge badge-light"> {{ app.user.commandes | length }}</span>
                                    commande(s)
                                </a>
                               </td>
                        </tr>
                    {% endif %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}
