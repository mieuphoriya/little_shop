{% extends 'base.html.twig' %}

{% block title %}Mes Commandes{% endblock %}

{% block body %}

    <div class="card col-md-12">
        <div class="card-header">
            <a class="btn-back text-secondary" href="{{ path('app_usager_commandes') }}">
                <i class="fas fa-2x fa-arrow-circle-left"></i>
            </a>
            <h3>
                Ma commande
                <span class="badge badge-pill badge-info">{{ commande.id }}</span>
                du
                {{ commande.dateCreation|date('d/m/Y \\à H:i') }}
                <span class="badge badge-pill badge-danger">
				en attente
				<i class="fas fa-hourglass-half"></i>
				</span>
                <br>
                Montant :
                {{ commande.getTotal()|number_format(2, ',', ' ') }}
                &nbsp;€
            </h3>
        </div>
        <div class="card-body row">
            <table class="table table-striped table-sm table-hover fit">
                <thead>
                <tr>
                    <th></th>
                    <th>Produit</th>
                    <th class="text-right">Prix</th>
                    <th>Quantité</th>
                    <th class="text-right">Total</th>
                </tr>
                </thead>
                <tbody>


                {% for ligne in commande.ligneCommandes %}

                    {% set produit = ligne.produit %}
                    {% set total = ligne.prix * ligne.quantite %}

                    <tr>
                        <td>
                            <img src="{{ asset(produit.visuel) }}"
                                 style="width: 80px">
                        </td>

                        <td>
                            <a href="{{ path('app_boutique_rayon', {'idCategorie': produit.categorie.getId()}) }}">
                                <b>{{ produit.libelle }}</b>
                            </a>
                        </td>

                        <td class="text-right">
                            {{ ligne.prix|number_format(2, ',', ' ') }} €
                        </td>

                        <td>
                            {{ ligne.quantite }}
                        </td>

                        <td class="text-right">
                            {{ total|number_format(2, ',', ' ') }} €
                        </td>
                    </tr>

                {% endfor %}
                </tbody>
                <tfoot>
                <tr>
                    <th class="text-right" colspan="4">
                        Total
                    </th>
                    <th class="text-right">
                        {{ commande.getTotal()|number_format(2, ',', ' ') }}
                        &nbsp;€
                    </th>
                </tr>
                </tfoot>

            </table>
        </div>
    </div>

{% endblock %}
