{% extends 'base.html.twig' %}

{% block body %}
    <h3>

        Recherche de

        "{{ searchedProduct }}" :

        {{  findedProducts | length }}

        {% trans %} boutique.rayon.mot_produits {% endtrans %}

        {#    produit(s)#}

    </h3>

    <!-- … -->
    {% for produit in findedProducts %}
        <div class="col-md-4">
            <div class="card clickable"

                {#                     lors du click sur l'element div "card clickable"
                        - redirection sur le Panier Controller : app_panier_ajouter - fonction  ajouter()
                        - idProduit' et  'quantite' sont les parametre de la fonction ajouter()
                #}

                 onclick="location = '{{ path('app_panier_ajouter', {'idProduit': produit.id, 'quantite': 1 }) }}'">

                <img src="{{ asset(produit.visuel) }} " class="card-img-produit"
                     alt="{{ produit.libelle }}">
                <div class="card-body">
                    <h4 class="card-title">{{ produit.libelle }}</h4>
                    <p class="card-text"><i>{{ produit.texte }}</i></p>
                    <h2>
<span class="badge badge-primary">
<i class="fas fa-cart-plus"></i> {{ produit.prix | currency_convert }}
</span>
                    </h2>
                </div>
            </div>
        </div>
    {% endfor %}

{% endblock %}
