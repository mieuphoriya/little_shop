
<div class="col-md-2" style="padding: 10px;">

    <div class="card">
        <div class="card-header text-center">
            <h5>
                <i class="fas fa-star"></i>
                Top Ventes								<i class="fas fa-star"></i>
            </h5>
        </div>

        <div class="card-body text-muted text-center">
            {% for article in articles %}
                <ul class="list-group">
                    <a href="{{ path('app_boutique_rayon', {'idCategorie': article.produit.categorie.getId()}) }}">
                        <li class="list-group-item text-center clickable top-produit">
                            <img src="{{ asset(article.produit.visuel) }}"style="height: 40px;">
                            <p class="top-produit">
                                {{ article.produit.libelle }}
                                <br>
                                <i>
                                    {{ article.total }}
                                    vente(s)
                                </i>
                            </p>
                        </li>
                    </a>
                </ul>
            {% endfor %}
        </div>

    </div>
</div>
